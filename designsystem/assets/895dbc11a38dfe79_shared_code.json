><line x1=\"8\" x2=\"16\" y1=\"21\" y2=\"21\"/><line x1=\"12\" x2=\"12\" y1=\"17\" y2=\"21\"/></svg>\n                    </div>\n                    <h4 class=\"font-semibold text-neutral-900\">Cross-Border E-com</h4>\n                    <p class=\"leading-relaxed text-sm font-normal text-neutral-500\">\n                        Track thousands of \"micro-gains\" from stablecoin price fluctuations. Perfect for high-volume merchants in UAE & SE Asia.\n                    </p>\n                </div>\n            </div>\n        </div>\n\n        <!-- CTA / Footer Card -->\n        <div class=\"mt-20 overflow-hidden min-h-[350px] shadow-2xl shadow-neutral-900/10 bg-neutral-900 rounded-[2.5rem] relative group transition-all duration-500 hover:shadow-lime-900/20 scroll-mt-24\">\n            \n            <!-- Grid Pattern & Glow -->\n            <div class=\"absolute inset-0 opacity-20\" style=\"background-image: linear-gradient(rgba(163,230,53,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(163,230,53,.1) 1px, transparent 1px); background-size: 40px 40px;\"></div>\n            <div class=\"absolute right-0 bottom-0 w-[500px] h-[500px] bg-lime-500/10 rounded-full blur-[100px] group-hover:bg-lime-500/20 transition-colors duration-1000\"></div>\n\n            <div class=\"grid grid-cols-1 lg:grid-cols-2 h-full relative z-10\">\n                <!-- Left: Content -->\n                <div class=\"p-8 md:p-12 flex flex-col justify-center h-full relative z-10\">\n                    <h3 class=\"text-3xl font-medium text-white tracking-tight mb-4\">Ready to automate your crypto books?</h3>\n                    <p class=\"text-neutral-400 text-sm mb-8 max-w-sm\">\n                        Join the fastest growing finance teams using Basisly to reconcile millions in stablecoin volume every month.\n                    </p>\n                    \n                    <div class=\"flex flex-col sm:flex-row gap-4\">\n                        <a href=\"#\" class=\"bg-lime-400 t