ter justify-between pb-4\">\n                <p class=\"text-neutral-400 text-[10px] font-normal\">\n                    © 2024 Basisly Inc. All rights reserved.\n                </p>\n                <div class=\"flex items-center gap-6 text-[10px] text-neutral-400\">\n                    <a href=\"#\" class=\"hover:text-neutral-600 transition-colors\">Privacy Policy</a>\n                    <a href=\"#\" class=\"hover:text-neutral-600 transition-colors\">Terms of Service</a>\n                </div>\n            </div>\n        </footer>\n    </main>\n</body>\n</html>","language":"html","username":"25d2a3ba-363e-4d1d-a6f0-b9c7b8f5c89b","created_at":"2025-12-31T06:08:49.030129+00:00","views":965,"image_url":"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/preview-images/shared-code-previews/basisly-stablecoin-2-preview-1767570981220.jpeg","forks":46,"private":false,"watermark":true,"featured":true,"share_source_code":true,"user_id":"25d2a3ba-363e-4d1d-a6f0-b9c7b8f5c89b","category":"Web","updated_at":null,"tags":["Landing Page","Technology","Brand","Clean","Gradient","Minimal","Large Type","Crypto","SaaS"],"description":"A modern SaaS landing page template for Basisly-style automated stablecoin accounting middleware, perfect for showcasing crypto-to-ERP automation products.","premium":false,"price":null,"purchase_url":null,"long_description":"**Basisly Stablecoin Accounting Landing Page Template**\n\nA high-conversion, SaaS-focused landing page template tailored for automated stablecoin and crypto accounting platforms.\n\n## What's Included\n- Hero section with bold headline, product narrative, and dual CTAs\n- Interactive middleware visual showing on-chain to ERP flow\n- Feature grid highlighting AI matching, FX, audit trail, and integrations\n- Target audience tiles for key segments (agencies, payroll, e‑com)\n- Dark CTA footer card and structured footer nav\n\n## Key Features\n- **Glassmorphism and gradient visuals** for a modern fintech/web3 aesthetic\n- **Enterprise feature layout**: FX attribution, gain/loss, audit trail, ERP sync\n- **Conversion-optimized CTAs**: Book Demo, Start Syncing, Get Early Access\n- **Audience-specific messaging** for Web3 agencies, remote payroll, e‑commerce\n- **Responsive Tailwind CSS layout** ready for customization\n\n**Primary Use Case:**\nUse this template to quickly launch a professional marketing site for stablecoin, crypto accounting, or finance automation products that integrate on-chain data with off-chain ERPs.","custom_domain":null,"favicon_light_url":null,"favicon_dark_url":null,"dns_verified":null,"dns_verified_at":null,"dns_a_record":null,"netlify_apex_exists":null,"netlify_www_exists":null,"netlify_verified_at":null,"custom_domain_added_at":null,"netlify_site_id":null,"umami_website_id":null,"umami_share_id":null,"analytics_enabled":false,"gtm_container_id":null,"remix_source":{},"credit_remix_source":false,"search_visibility":"aura_and_custom_domain"}]