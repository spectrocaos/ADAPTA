[{"id":11146,"slug":"basisly-stablecoin-2","title":"Stablecoin Accounting SaaS Landing Page Template","code":"<html lang=\"en\" class=\"scroll-smooth\">\n<head>\n<script>\ntry{if(window.parent&&window.parent!==window){window.parent.promotekit_referral=\"1fd2949a-d22c-431b-92bf-02d4ad04ee24\";window.parent.document.cookie=\"promotekit_referral=1fd2949a-d22c-431b-92bf-02d4ad04ee24;path=/;domain=.aura.build;max-age=31536000\"}}catch(e){}\n</script>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Basisly - Automated Stablecoin Accounting Middleware</title>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script src=\"https://code.iconify.design/3/3.1.0/iconify.min.js\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600&amp;display=swap\" rel=\"stylesheet\">\n<style>\nbody { font-family: 'Inter', sans-serif; }\n/* Curve separators */\n.curve-separator {\nbackground-image: url(\"data:image/svg+xml,%3Csvg width='20' height='60' viewBox='0 0 20 60' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M18 1C18 1 1 15 1 30C1 45 18 59 18 59' stroke='%23a3e635' stroke-width='0.5' stroke-linecap='round'/%3E%3C/svg%3E\");\nbackground-repeat: no-repeat;\nbackground-position: center;\nwidth: 20px;\nheight: 40px;\n}\n.curve-separator-right { transform: scaleX(-1); }\n/* Glass effects */\n.glass-panel {\nbackground: rgba(255, 255, 255, 0.92);\nbackdrop-filter: blur(16px);\n-webkit-backdrop-filter: blur(16px);\n}\n.glass-card {\nbackground: rgba(255, 255, 255, 0.6);\nbackdrop-filter: blur(8px);\nborder: 1px solid rgba(255, 255, 255, 0.8);\n}\n/* Animations */\n@keyframes fadeInUp {\nfrom { opacity: 0; transform: translateY(20px); }\nto { opacity: 1; transform: translateY(0); }\n}\n@keyframes fadeInScale {\nfrom { opacity: 0; transform: scale(0.98); }\nto { opacity: 1; transform: scale(1); }\n}\n@keyframes float {\n0% { transform: translateY(0px); }\n50% { transform: translateY(-8px); }\n100% { transform: translateY(0px); }\n}\n@keyframes pulse-glow {\n0%, 100% { box-shadow: 0 0 15px rgba(163, 230, 53, 0.2); }\n50% { box-shadow: 0 0 25px rgba(163, 230, 53, 0.5); }\n}\n@keyframes shimmer {\n0% { background-position: -200% 0; }\n100% { background-position: 200% 0; }\n}\n@keyframes slide-infinite {\n0% { transform: translateX(0); }\n100% { transform: translateX(-50%); }\n}\n/* Utility Classes for Animation */\n.animate-fade-up { opacity: 0; animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }\n.animate-fade-scale { opacity: 0; animation: fadeInScale 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards; }\n.animate-float { animation: float 6s ease-in-out infinite; }\n.animate-pulse-glow { animation: pulse-glow 3s infinite; }\n/* Delays */\n.delay-100 { animation-delay: 100ms; }\n.delay-200 { animation-delay: 200ms; }\n.delay-300 { animation-delay: 300ms; }\n.delay-400 { animation-delay: 400ms; }\n.delay-500 { animation-delay: 500ms; }\n.delay-700 { animation-delay: 700ms; }\n</style>\n<script>\ntailwind.config = {\ntheme: {\nextend: {\ncolors: {\nlime: {\n300: '#bef264',\n400: '#a3e635',\n500: '#84cc16',\n950: '#1a2e05',\n}\n}\n}\n},\nplugins: [\nfunction({ addUtilities }) {\naddUtilities({\n'.perspective-1000': { perspective: '1000px' },\n'.transform-style-preserve-3d': { transformStyle: 'preserve-3d' },\n});\n}\n]\n};\n</script>\n<style>\n/* 3D Transform utilities */\n.transform-style-preserve-3d { transform-style: preserve-3d !important; }\n</style></head>\n<body class=\"flex justify-center items-center min-h-screen selection:bg-lime-400 selection:text-black xl:p-8 text-neutral-800 bg-neutral-100 bg-cover px-0 py-0 relative\">\n\n    <!-- Background Decoration -->\n    <div class=\"fixed inset-0 z-0 pointer-events-none overflow-hidden\">\n        <div class=\"absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-lime-300/20 rounded-full blur-[120px]\"></div>\n        <div class=\"absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-neutral-300/30 rounded-full blur-[120px]\"></div>\n    </div>\n\n    <!-- Main Frame Container -->\n    <main class=\"glass-panel overflow-hidden flex flex-col xl:max-w-[1300px] z-10 xl:border-white/60 border-none xl:border xl:rounded-[2.5rem] md:pt-10 md:pr-10 md:pb-10 md:pl-10 xl:pt-12 xl:pr-12 xl:pb-12 xl:pl-12 xl:shadow-2xl min-h-screen w-full rounded-none pt-6 pr-6 pb-6 pl-6 relative shadow-none animate-fade-scale\">\n        \n        <!-- Vertical Grid Lines -->\n        <div class=\"absolute inset-0 flex justify-between pointer-events-none z-0 px-6 md:px-10 xl:px-12 w-full h-full opacity-30\">\n            <div class=\"h-full w-[1px] bg-neutral-900/5\"></div>\n            <div class=\"h-full w-[1px] bg-neutral-900/5 hidden md:block\"></div>\n            <div class=\"h-full w-[1px] bg-neutral-900/5 hidden lg:block\"></div>\n            <div class=\"h-full w-[1px] bg-neutral-900/5 hidden xl:block\"></div>\n            <div class=\"h-full w-[1px] bg-neutral-900/5\"></div>\n        </div>\n\n        <!-- Header -->\n        <header class=\"flex md:mb-20 md:gap-0 z-10 mb-16 relative gap-x-6 gap-y-6 items-center justify-between animate-fade-up\">\n            <!-- Logo -->\n            <a href=\"#\" class=\"flex items-center gap-2 text-neutral-900 group cursor-pointer\">\n                <div class=\"flex text-neutral-900 bg-lime-400 w-8 h-8 rounded-lg items-center justify-center shadow-[0_0_15px_rgba(163,230,53,0.4)] transition-transform duration-500 group-hover:rotate-180\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 12V7H5a2 2 0 0 1 0-4h14v4\"/><path d=\"M3 5v14a2 2 0 0 0 2 2h16v-5\"/><path d=\"M18 12a2 2 0 0 0 0 4h4v-4Z\"/></svg>\n                </div>\n                <span class=\"text-sm font-semibold tracking-tight\">Basisly</span>\n            </a>\n\n            <!-- Navigation -->\n            <nav class=\"hidden md:flex uppercase text-[10px] font-semibold text-neutral-500 tracking-widest bg-white/40 border-white/60 border rounded-full pt-2.5 pr-6 pb-2.5 pl-6 shadow-sm backdrop-blur-md gap-x-8 items-center transition-all hover:shadow-md hover:bg-white/80\">\n                <a href=\"#product\" class=\"hover:text-neutral-900 transition-colors duration-300 relative group\">\n                    Platform\n                    <span class=\"absolute -bottom-1 left-0 w-0 h-0.5 bg-lime-400 transition-all duration-300 group-hover:w-full\"></span>\n                </a>\n                <a href=\"#features\" class=\"hover:text-neutral-900 transition-colors duration-300 relative group\">\n                    Features\n                    <span class=\"absolute -bottom-1 left-0 w-0 h-0.5 bg-lime-400 transition-all duration-300 group-hover:w-full\"></span>\n                </a>\n                <a href=\"#integrations\" class=\"hover:text-neutral-900 transition-colors duration-300 relative group\">\n                    Integrations\n                    <span class=\"absolute -bottom-1 left-0 w-0 h-0.5 bg-lime-400 transition-all duration-300 group-hover:w-full\"></span>\n                </a>\n            </nav>\n\n            <!-- CTA -->\n            <a href=\"#\" class=\"flex items-center gap-2 group hover:bg-neutral-50 text-xs font-medium text-neutral-800 tracking-wide bg-white border border-neutral-200 rounded-lg pt-2 pr-4 pb-2 pl-4 shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5\">\n                <span class=\"uppercase tracking-wide text-[10px] font-semibold\">Book Demo</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-lime-500 group-hover:translate-x-0.5 transition-transform\"><path d=\"M5 12h14\"/><path d=\"m12 5 7 7-7 7\"/></svg>\n            </a>\n        </header>\n\n        <!-- Content Grid -->\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 h-full flex-grow relative z-10 pb-8 lg:pb-0\">\n            \n            <!-- Left Column: Hero Content -->\n            <div id=\"product\" class=\"lg:col-span-7 flex flex-col pt-4 relative justify-center scroll-mt-32\">\n                \n                <!-- Status Pill -->\n                <div class=\"animate-fade-up delay-100 inline-flex bg-white/60 w-max rounded-full mb-8 pt-1.5 pr-4 pb-1.5 pl-1.5 shadow-sm backdrop-blur-sm items-center border border-white/50 group cursor-default\">\n                    <span class=\"flex h-2 w-2 relative mr-3 ml-1\">\n                        <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-lime-400 opacity-75\"></span>\n                        <span class=\"relative inline-flex rounded-full h-2 w-2 bg-lime-500\"></span>\n                    </span>\n                    <span class=\"text-xs font-medium text-neutral-600 tracking-wide\">\n                        Live Integration: <span class=\"text-neutral-900 font-semibold ml-1\">QuickBooks & NetSuite</span>\n                    </span>\n                </div>\n\n                <!-- Headline -->\n                <h1 class=\"animate-fade-up delay-200 leading-[0.9] lg:text-[4rem] text-5xl font-semibold text-neutral-900 tracking-tighter mb-8\">\n                    Stablecoin Accounting, <br>\n                    <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-lime-500 to-lime-600 font-medium\">Fully Automated.</span>\n                </h1>\n\n                <!-- Subheadline -->\n                <p class=\"animate-fade-up delay-300 text-sm text-neutral-500 font-normal max-w-lg mb-10 leading-relaxed tracking-wide border-l-2 border-lime-300 pl-6\">\n                    The financial middleware bridging on-chain data to off-chain ERPs. Monitor wallets, attribute real-time cost basis, and sync GAAP-ready journal entries automatically.\n                </p>\n\n                <!-- Action Buttons -->\n                <div class=\"animate-fade-up delay-400 flex flex-col sm:flex-row gap-3 lg:mb-24 mb-16 gap-x-3 gap-y-3\">\n                    <a href=\"#\" class=\"hover:bg-lime-300 hover:-translate-y-1 hover:shadow-[0_10px_30px_-10px_rgba(163,230,53,0.4)] transition-all duration-300 flex group text-sm font-semibold text-neutral-900 bg-lime-400 rounded-full pt-3.5 pr-7 pb-3.5 pl-7 shadow-xl gap-x-2 items-center justify-center min-w-[160px]\">\n                        <span class=\"tracking-tight\">Start Syncing</span>\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"group-hover:translate-x-1 transition-transform\"><path d=\"M13 2L3 14h9l-1 8 10-12h-9l1-8z\"/></svg>\n                    </a>\n                    <a href=\"#\" class=\"hover:bg-white hover:-translate-y-1 hover:shadow-md transition-all duration-300 flex text-sm font-medium text-neutral-600 bg-white/60 border border-neutral-200 rounded-full pt-3.5 pr-6 pb-3.5 pl-6 shadow-sm gap-x-2 items-center justify-center group backdrop-blur-sm\">\n                        <span class=\"tracking-tight\">View Documentation</span>\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"group-hover:text-lime-600 transition-colors\"><path d=\"M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z\"/><path d=\"M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z\"/></svg>\n                    </a>\n                </div>\n\n                <!-- Footer Stats -->\n                <div class=\"animate-fade-up delay-500 flex flex-wrap gap-2 md:gap-6 mt-auto gap-x-2 gap-y-2 items-center\">\n                    <div class=\"flex items-center group cursor-default\">\n                        <div class=\"px-1\">\n                            <p class=\"text-[10px] font-semibold text-neutral-400 uppercase tracking-widest mb-1\">Supported Assets</p>\n                            <p class=\"text-sm text-neutral-900 font-medium flex items-center gap-1\">\n                                USDC / USDT / DAI\n                            </p>\n                        </div>\n                        <div class=\"curve-separator opacity-60 ml-4 md:ml-8\"></div>\n                    </div>\n                    <div class=\"flex items-center group cursor-default\">\n                        <div class=\"px-1\">\n                            <p class=\"text-[10px] font-semibold text-neutral-400 uppercase tracking-widest mb-1\">Compliance</p>\n                            <p class=\"text-sm text-neutral-900 font-medium\">GAAP & IFRS Ready</p>\n                        </div>\n                        <div class=\"curve-separator md:ml-8 opacity-60 ml-4\"></div>\n                    </div>\n                    <div class=\"flex items-center group cursor-default\">\n                        <div class=\"px-1\">\n                            <p class=\"text-[10px] font-semibold text-neutral-400 uppercase tracking-widest mb-1\">Precision</p>\n                            <p class=\"text-sm text-neutral-900 font-medium\">Block-Timestamp FX</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Right Column: Visual Middleware Representation -->\n            <div class=\"lg:col-span-5 h-full min-h-[450px] lg:min-h-0 relative group perspective-1000 animate-fade-scale delay-300\">\n                <div class=\"absolute inset-0 rounded-[2.5rem] overflow-hidden shadow-2xl shadow-neutral-200/50 transition-all duration-700 ease-out border border-white/60 bg-gradient-to-br from-neutral-50 to-white/80\">\n                    \n                    <!-- Abstract Tech Background -->\n                    <div class=\"absolute inset-0 opacity-[0.03]\" style=\"background-image: radial-gradient(#000 1px, transparent 1px); background-size: 20px 20px;\"></div>\n                    <div class=\"absolute -right-20 -top-20 w-80 h-80 bg-lime-200/30 rounded-full blur-[80px] animate-pulse-glow\"></div>\n\n                    <!-- Main UI Card Container -->\n                    <div class=\"flex flex-col items-center justify-center h-full w-full p-8 relative\">\n                        \n                        <!-- Top Card: On-Chain (Input) -->\n                        <div class=\"w-full bg-white rounded-xl shadow-lg border border-neutral-100 p-4 mb-4 transform transition-transform duration-500 group-hover:-translate-y-2 relative z-20\">\n                            <div class=\"flex justify-between items-center mb-3\">\n                                <div class=\"flex items-center gap-2\">\n                                    <div class=\"w-6 h-6 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-600\">\n                                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8\"/><path d=\"M12 18V6\"/></svg>\n                                    </div>\n                                    <span class=\"text-[10px] font-mono text-neutral-500\">0x7a...4b2c</span>\n                                </div>\n                                <span class=\"text-xs font-semibold text-neutral-900\">+ 5,000.00 USDC</span>\n                            </div>\n                            <div class=\"h-1 w-full bg-neutral-100 rounded-full overflow-hidden\">\n                                <div class=\"h-full bg-blue-500 w-full animate-[shimmer_2s_infinite]\"></div>\n                            </div>\n                        </div>\n\n                        <!-- Middle Connection: Basisly Engine -->\n                        <div class=\"relative z-10 my-[-10px] flex flex-col items-center justify-center\">\n                            <div class=\"h-12 w-[2px] bg-gradient-to-b from-blue-200 to-lime-400\"></div>\n                            <div class=\"bg-neutral-900 text-white rounded-full p-1.5 shadow-xl shadow-lime-400/20 border border-lime-400/50 z-20 animate-float\">\n                                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-lime-400\"><path d=\"M12 2v20\"/><path d=\"m17 5-5-3-5 3\"/><path d=\"m17 19-5 3-5-3\"/></svg>\n                            </div>\n                            <div class=\"absolute left-10 top-4 bg-white/90 backdrop-blur-md px-3 py-1.5 rounded-lg shadow-sm border border-neutral-100 text-[10px] font-mono whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100\">\n                                <span class=\"text-neutral-400\">FX Rate:</span> <span class=\"text-neutral-900\">$1.0002</span>\n                            </div>\n                            <div class=\"h-12 w-[2px] bg-gradient-to-b from-lime-400 to-green-600\"></div>\n                        </div>\n\n                        <!-- Bottom Card: Off-Chain (Output) -->\n                        <div class=\"w-full bg-white rounded-xl shadow-lg border-l-4 border-l-lime-500 border-y border-r border-neutral-100 p-4 mt-4 transform transition-transform duration-500 group-hover:translate-y-2 relative z-20\">\n                            <div class=\"flex justify-between items-center mb-2\">\n                                <div class=\"flex items-center gap-2\">\n                                    <span class=\"text-[10px] font-bold text-neutral-400 tracking-wider\">NETSUITE / QBO</span>\n                                </div>\n                                <div class=\"flex items-center gap-1 bg-lime-100 px-2 py-0.5 rounded-full\">\n                                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-lime-700\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n                                    <span class=\"text-[10px] font-bold text-lime-800 uppercase\">Reconciled</span>\n                                </div>\n                            </div>\n                            <div class=\"space-y-2\">\n                                <div class=\"flex justify-between text-[10px] border-b border-neutral-50 pb-1\">\n                                    <span class=\"text-neutral-500\">Credit: Revenue</span>\n                                    <span class=\"font-mono text-neutral-800\">$5,001.00</span>\n                                </div>\n                                <div class=\"flex justify-between text-[10px]\">\n                                    <span class=\"text-neutral-500\">Debit: Digital Asset</span>\n                                    <span class=\"font-mono text-neutral-800\">$5,001.00</span>\n                                </div>\n                            </div>\n                        </div>\n\n                    </div>\n                    \n                    <!-- Code Overlay -->\n                    <div class=\"absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white via-white/80 to-transparent pointer-events-none z-30\"></div>\n                </div>\n            </div>\n        </div>\n\n        <!-- Divider -->\n        <div class=\"w-full h-px bg-gradient-to-r from-transparent via-neutral-200 to-transparent mt-16 lg:mt-24 mb-16 lg:mb-24 opacity-60\"></div>\n\n        <!-- Features Section -->\n        <div id=\"features\" class=\"flex flex-col gap-10 z-10 w-full relative gap-x-10 gap-y-10 animate-fade-up delay-200 scroll-mt-24\">\n            <div class=\"flex flex-col md:flex-row md:items-end justify-between gap-6 px-1\">\n                <div class=\"max-w-2xl\">\n                    <h2 class=\"md:text-4xl text-3xl font-medium text-neutral-900 tracking-tighter mb-4\">\n                        Enterprise-Grade Precision\n                    </h2>\n                    <p class=\"leading-relaxed text-base font-normal text-neutral-500\">\n                        Stop manual data entry. We automate the complexities of crypto accounting so you can close your books faster.\n                    </p>\n                </div>\n            </div>\n\n            <!-- Bento Grid: Features -->\n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 overflow-hidden shadow-sm bg-neutral-200 rounded-[2rem] gap-px border border-neutral-200\">\n                \n                <!-- Feature 1: Real-Time FX -->\n                <div class=\"group hover:bg-white transition-all duration-300 flex flex-col min-h-[280px] bg-neutral-50 h-full p-8 relative justify-between z-10\">\n                    <div>\n                        <div class=\"w-10 h-10 bg-white rounded-lg border border-neutral-200 flex items-center justify-center mb-6 shadow-sm text-lime-600 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>\n                        </div>\n                        <h3 class=\"text-lg font-semibold text-neutral-900 mb-2 tracking-tight\">Real-Time FX Attribution</h3>\n                        <p class=\"text-sm text-neutral-500 font-normal leading-relaxed\">\n                            We pull the exact USD/EUR price at the specific block-timestamp of every transaction for audit-ready accuracy.\n                        </p>\n                    </div>\n                </div>\n\n                <!-- Feature 2: AI Matching (Large) -->\n                <div class=\"group relative bg-white hover:bg-lime-50/30 transition-colors p-8 flex flex-col justify-between h-full min-h-[280px] md:col-span-2 overflow-hidden z-10\">\n                    <div class=\"relative z-10 max-w-md\">\n                        <div class=\"w-10 h-10 bg-lime-50 rounded-lg border border-lime-200 flex items-center justify-center mb-6 shadow-sm text-lime-600 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"/><path d=\"m12 8.5 4.5 2.5\"/><path d=\"m12 15.5 4.5-2.5\"/><path d=\"m12 12 4.5-2.5\"/><path d=\"m12 12-4.5-2.5\"/><path d=\"M12 3.5v17\"/></svg>\n                        </div>\n                        <h3 class=\"text-lg font-semibold text-neutral-900 mb-2 tracking-tight\">AI Smart-Matching</h3>\n                        <p class=\"text-sm text-neutral-500 font-normal leading-relaxed\">\n                            Our ML engine pairs incoming wallet addresses with open invoices in your ERP, automatically marking them as \"Paid\" without human intervention.\n                        </p>\n                    </div>\n                    <div class=\"absolute right-0 bottom-0 top-0 w-1/2 bg-gradient-to-l from-white to-transparent pointer-events-none\"></div>\n                    <div class=\"absolute bottom-6 right-6 opacity-10 group-hover:opacity-100 transition-opacity duration-500 text-lime-500\">\n                         <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"120\" height=\"120\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"0.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 2a10 10 0 1 0 10 10H12V2z\"/><path d=\"M12 2a10 10 0 0 1 10 10h-10V2z\" transform=\"rotate(180 12 12)\" opacity=\"0.5\"/></svg>\n                    </div>\n                </div>\n\n                <!-- Feature 3: Gain/Loss Ledger -->\n                <div class=\"group hover:bg-white transition-all duration-300 flex flex-col min-h-[280px] bg-neutral-50 h-full p-8 relative justify-between z-10\">\n                    <div>\n                        <div class=\"w-10 h-10 bg-white rounded-lg border border-neutral-200 flex items-center justify-center mb-6 shadow-sm text-neutral-700 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 20v-6\"/><path d=\"M6 20V10\"/><path d=\"M18 20V4\"/></svg>\n                        </div>\n                        <h3 class=\"text-lg font-semibold text-neutral-900 mb-2 tracking-tight\">Auto Gain/Loss</h3>\n                        <p class=\"text-sm text-neutral-500 font-normal leading-relaxed\">\n                            Track \"micro-fluctuations\" in stablecoin values to ensure your books remain perfectly balanced to the cent.\n                        </p>\n                    </div>\n                </div>\n\n                <!-- Feature 4: Audit Trail -->\n                <div class=\"group hover:bg-white transition-all duration-300 flex flex-col min-h-[280px] bg-neutral-50 h-full p-8 relative justify-between z-10\">\n                    <div>\n                        <div class=\"w-10 h-10 bg-white rounded-lg border border-neutral-200 flex items-center justify-center mb-6 shadow-sm text-neutral-700 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/><polyline points=\"14 2 14 8 20 8\"/><path d=\"m9 15 2 2 4-4\"/></svg>\n                        </div>\n                        <h3 class=\"text-lg font-semibold text-neutral-900 mb-2 tracking-tight\">Immutable Audit Trail</h3>\n                        <p class=\"text-sm text-neutral-500 font-normal leading-relaxed\">\n                            Every accounting entry is directly linked to its unique blockchain Transaction ID (TXID) as \"Proof of Payment\".\n                        </p>\n                    </div>\n                </div>\n\n                <!-- Feature 5: Integration -->\n                <div class=\"group hover:bg-white transition-all duration-300 flex flex-col min-h-[280px] bg-neutral-50 h-full p-8 relative justify-between z-10\">\n                    <div>\n                        <div class=\"w-10 h-10 bg-white rounded-lg border border-neutral-200 flex items-center justify-center mb-6 shadow-sm text-neutral-700 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"/><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"/></svg>\n                        </div>\n                        <h3 class=\"text-lg font-semibold text-neutral-900 mb-2 tracking-tight\">ERP Native Sync</h3>\n                        <p class=\"text-sm text-neutral-500 font-normal leading-relaxed\">\n                            Seamless integration with QuickBooks Online, NetSuite, and Xero. No CSV exports required.\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- Divider -->\n        <div class=\"w-full h-px bg-gradient-to-r from-transparent via-neutral-200 to-transparent mt-16 lg:mt-24 mb-16 lg:mb-24 opacity-60\"></div>\n\n        <!-- Target Audience Section -->\n        <div class=\"flex flex-col gap-16 z-10 w-full relative animate-fade-up delay-300\">\n            <h2 class=\"text-center text-2xl font-medium text-neutral-900 tracking-tight\">Trusted by high-growth crypto operators</h2>\n            <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12\">\n                \n                <!-- Audience 1 -->\n                <div class=\"flex flex-col gap-4 group cursor-default p-6 rounded-2xl border border-transparent hover:border-neutral-100 hover:bg-white/50 transition-all duration-300\">\n                    <div class=\"text-lime-600 group-hover:scale-110 transition-transform duration-300 origin-left\">\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.87a.5.5 0 0 0-.494-.493l-5.506.373\"/><path d=\"M15 13v-3\"/><path d=\"M12 21a9 9 0 0 0 9-9 9 9 0 0 0-9-9 9 9 0 0 0-9 9 9 9 0 0 0 9 9Z\"/><path d=\"M7 14v-4\"/><path d=\"M11 14v-4\"/></svg>\n                    </div>\n                    <h4 class=\"font-semibold text-neutral-900\">Web3 Agencies</h4>\n                    <p class=\"le